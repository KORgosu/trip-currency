# AWS 환경 변수 템플릿
# 이 파일을 복사한 후 실제 값으로 채워서 .env.aws 파일을 만드세요.
#   cp .env.aws.example .env.aws
# 실제 .env.aws는 .gitignore에 등록되어 Git에 추적되지 않습니다.
#
# 사용법 (kustomization.yaml 적용 전 envsubst 실행):
#   source .env.aws
#   envsubst < k8s/overlays/eks/kustomization.yaml | kubectl apply -f -
#   envsubst < aws/iam/ebs-csi-trust.json.template > aws/iam/ebs-csi-trust.json
#   envsubst < aws/eks/cluster-config.yaml.template > aws/eks/cluster-config.yaml

# ── AWS 계정 정보 ──────────────────────────────────────────────────────────────
# aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# EKS OIDC Provider ID (ARN의 /id/ 이후 부분)
# aws eks describe-cluster --name <cluster-name> --query "cluster.identity.oidc.issuer"
EKS_OIDC_ID=YOUR_OIDC_ID

# ── VPC / 네트워크 ────────────────────────────────────────────────────────────
# aws ec2 describe-vpcs
VPC_ID=YOUR_VPC_ID

# 퍼블릭 서브넷 ID (ap-northeast-2a/2b/2c)
SUBNET_PUBLIC_2A=YOUR_PUBLIC_SUBNET_2A
SUBNET_PUBLIC_2B=YOUR_PUBLIC_SUBNET_2B
SUBNET_PUBLIC_2C=YOUR_PUBLIC_SUBNET_2C

# 프라이빗 서브넷 ID (ap-northeast-2a/2b/2c)
SUBNET_PRIVATE_2A=YOUR_PRIVATE_SUBNET_2A
SUBNET_PRIVATE_2B=YOUR_PRIVATE_SUBNET_2B
SUBNET_PRIVATE_2C=YOUR_PRIVATE_SUBNET_2C

# ── 데이터베이스 엔드포인트 ───────────────────────────────────────────────────
# aws rds describe-db-clusters --query "DBClusters[].Endpoint"
AURORA_ENDPOINT=YOUR_AURORA_CLUSTER_ENDPOINT.rds.amazonaws.com

# aws docdb describe-db-clusters --query "DBClusters[].Endpoint"
DOCDB_ENDPOINT=YOUR_DOCDB_CLUSTER_ENDPOINT.docdb.amazonaws.com

# aws elasticache describe-replication-groups --query "ReplicationGroups[].NodeGroups[].PrimaryEndpoint"
REDIS_ENDPOINT=YOUR_REDIS_CLUSTER_ENDPOINT.cache.amazonaws.com

# ── ACM 인증서 ────────────────────────────────────────────────────────────────
# aws acm list-certificates --query "CertificateSummaryList[].CertificateArn"
ACM_CERT_ARN=arn:aws:acm:ap-northeast-2:YOUR_AWS_ACCOUNT_ID:certificate/YOUR_CERT_ID
